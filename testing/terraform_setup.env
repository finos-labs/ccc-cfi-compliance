# Terraform Setup Environment Variables
# These are non-secret configuration values used to inject dynamic names into Terraform and CCC tests
# TF_VAR_* format allows Terraform to pick them up automatically
#
# For local testing, source this file:
#   source testing/terraform_setup.env

# ALL
# Generate a unique INSTANCE_ID using unix timestamp to avoid conflicts in concurrent or serial runs
export INSTANCE_ID=$(date +%s)
export TF_VAR_instance_id=${INSTANCE_ID}