# Terraform Setup Environment Variables
# These are non-secret configuration values used to inject dynamic names into Terraform and CCC tests
# TF_VAR_* format allows Terraform to pick them up automatically
#
# Source this file once (local or CI), then persist exported vars as needed for your runner (e.g. GITHUB_ENV).
#   set -a && source testing/terraform_setup.env && set +a

# ALL — unique ID for Terraform / CCC tests (UTC compact, e.g. 20240401t161714z)
# If INSTANCE_ID is already set (e.g. GHA workflow_dispatch, or `export` before sourcing), it is not replaced.
export INSTANCE_ID="${INSTANCE_ID:-$(date -u +"%Y%m%dt%H%M%Sz")}"
export TF_VAR_instance_id="${INSTANCE_ID}"

# VPC (AWS) — CN03/CN04 feature flags (scoped to avoid Terraform warnings on non-VPC targets)
if [ "${TARGET_PROVIDER:-}" = "aws" ] && [ "${TARGET_SERVICE:-}" = "networking" ]; then
  export TF_VAR_cn03_create_peers=true
  export TF_VAR_cn03_create_non_allowlisted_requester=true
  export TF_VAR_cn03_apply_guardrail=true
  export TF_VAR_cn04_enable_flow_logs=true
fi
