# Compliance Testing Environment Variables
# These are non-secret configuration values for CCC compliance tests
# TF_VAR_* format allows Terraform to pick them up automatically
#
# For local development, source this file:
#   source testing/compliance-testing.env

# AWS
export AWS_REGION=us-east-1
# CN_TEST_AMI_ID: AMI used for behavioral EC2 instance checks (CN02/CN04 OPT_IN scenarios).
# Set to a valid AMI ID for the target region before running opt-in behavioral tests.
export CN_TEST_AMI_ID=

# CCC.VPC.CN02 OPT_IN: AMI ID for short-lived test instance (region-specific).
# Leave blank to skip the behavioral check; set to a valid AMI ID to enable it.
export CN_TEST_AMI_ID=

# Azure
export TF_VAR_subscription_id=c1cedd8e-bf91-4d7d-a4cc-45700402a2a1
export TF_VAR_storage_account_name=storagecfitesting2026
export TF_VAR_resource_group_name=cfi_test
export TF_VAR_location=eastus
export ARM_SUBSCRIPTION_ID=$TF_VAR_subscription_id

# GCP
export TF_VAR_gcp_project_id=nodal-time-474015-p5
export TF_VAR_gcp_region=us-central1